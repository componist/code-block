{
    "name": "componist/code-block",
    "description": "Laravel client for Template Archive API – fetch code blocks, categories, template images and write Blade templates to resources/views/pages",
    "type": "library",
    "homepage": "https://componist.dev",
    "license": "MIT",
    "keywords": [
        "laravel",
        "componist",
        "code-block",
        "api",
        "blade",
        "templates",
        "archive",
        "html",
        "css",
        "js"
    ],
    "authors": [
        {
            "name": "Componist Developer",
            "email": "info@componist.dev",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2 || ^8.3 || ^8.4",
        "illuminate/support": "^11.0 || ^12.0 || ^13.0",
        "illuminate/http": "^11.0 || ^12.0 || ^13.0",
        "illuminate/filesystem": "^11.0 || ^12.0 || ^13.0",
        "illuminate/config": "^11.0 || ^12.0 || ^13.0",
        "illuminate/console": "^11.0 || ^12.0 || ^13.0",
        "componist/code-block-tracking": "@dev"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "larastan/larastan": "^3.9"
    },
    "scripts": {
        "phpstan": "phpstan analyse -c phpstan.neon.dist"
    },
    "autoload": {
        "psr-4": {
            "Componist\\CodeBlock\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-master": "1.0.x-dev"
        },
        "laravel": {
            "providers": [
                "Componist\\CodeBlock\\CodeBlockServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
